var<-c("GRADE1","GRADE2","GRADE3","GRADE4","GRADE5","OVERALL")
t5<-NULL
for(i in 1:length(var)){
te<-te1[te1[,var[i]]=="Yes",]
aeall<-addvar(te,c("AEDECOD"),"AEDECOD","length(x)","no","N_AE")#,"AEDECOD" "AESOC"
aeall1<-addvar(nodup(te,c("USUBJID","AEDECOD"),"all"),c("AEDECOD"),"AEDECOD","length(x)","no","N_SUBJ")
aeall1$fil<-aeall1$N_SUBJ/totid*100
#aeall1<-aeall1[aeall1$fil>=10,]
aeall1$fil<-NULL
if(nrow(aeall1)>0){
z<-paste0("AE_EVENT",i)
zz<-paste0("AE_SUBJ",i)
aeall[,z]<-with(aeall,paste0(N_AE," (",sigfig(N_AE/totae*100,3),"%)"))
aeall1[,zz]<-with(aeall1,paste0(N_SUBJ," (",sigfig(N_SUBJ/totid*100,3),"%)"))
tx<-lhlong(left_join(aeall1,aeall)[,c("AEDECOD",z,zz)],c(z,zz))}else{tx<-NULL}
head(t5)
head(tx)
t5<-rbind(t5,tx)
}
