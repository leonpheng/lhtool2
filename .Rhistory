# sp$PMAWEEK<-sp$PNAWEEK+42 # EGFR PMA in WEEK
pop<-read.csv("../../PED_POPULATION/neonate.csv")
th<-read.csv("../../../modeling/refit_run029_XIE_Healthy/Theta.csv")
om<-read.csv("../../../modeling/refit_run029_XIE_Healthy/Omega.csv")
head(pop)
pop<-nodup(pop,"id","all")
unique(pop$ageycat)
pop$ageycat<-"< 1 month"
length(unique(pop$id))
#print(addvar(pop,"ageycat","id","length(x)","no"))
#k1<-unique(pop$ageycat)[grep("2 to 6 years",unique(pop$ageycat))]
#k2<-unique(pop$ageycat)[grep("1 month to 2 years",unique(pop$ageycat))]
#pop<-pop[pop$ageycat%in%c(as.character(k1),as.character(k2)),]
##Prepare PK for sim
#GENERATE OMEGA
keep<-unique(names(om[,3:ncol(om)]))
start<-as.numeric(row.names(om[om$Label=="Omega",]))+1
stop<-as.numeric(row.names(om[om$Label=="Correlation",]))-1
omeg<-om[start:stop,3:ncol(om)]
list(omeg)
omeg<-chclass(omeg,names(omeg),"num")
names(omeg)<-NULL
x<-NULL
for(i in 1:nrow(omeg)){
z<-omeg[i,][!is.na(omeg[i,])]
x<-c(x,z)
}
nr<-nrow(pop)
set.seed(12345)
eta<-as.data.frame(generateETA(nr,unlist(x),eta.names=keep))
head(pop)
pop$AGEYcat<-pop$ageycat
#pop$WT<-pop$wt
pop$ID<-pop$id
eta$ID<-pop$ID
head(pop)
for(i in c("ID","PNAWEEK","PMAWEEK","WT","AGEYcat")){
eta[,i]<-pop[,i]}
eta<-lhmutate(eta,c("PNAWEEK=PNA","PMAWEEK=PMA"))
thx<-lhwide(th[,c("Scenario","Parameter","Estimate")],"Estimate","Parameter")
thx$Scenario<-thx$stdev0<-NULL
for(i in names(thx)){
eta[,i]<-thx[,i]
}
unique(eta$AGEYcat)
folder<-"QID_BirthWeight"
dir.create(paste0("./output/",folder))
k<-NULL
k[[1]]<-c("< 1 month")
#k[[2]]<-c("2 to 6 years 10-15 kg","2 to 6 years 15-30 kg","2 to 6 years >30 kg")
#k[[3]]<-c("2 to 6 years <15 kg","2 to 6 years 15-20 kg","2 to 6 years 20-30 kg")
#k[[4]]<-c("6 to 12 years 15-30 kg","6 to 12 years 30-45 kg","6 to 12 years >45 kg")
#k[[5]]<-c("6 to 12 years 15-25 kg","6 to 12 years 25-35 kg","6 to 12 years 35-45 kg","6 to 12 years >45 kg")
#k[[6]]<-c("12 to 17 years (25-45 kg)","12 to 17 years (30-45 kg)","12 to 17 years (>=45 kg)")
group<-c("neonate")
#f=1
for(f in 1:length(k)){
keep<-k[[f]]
sp2<-eta[eta$AGEYcat%in%keep,]
sp2<-eta[eta$AGEYcat%in%keep&eta$ID%in%unique(eta$ID)[1:10],]
#sp2$AGEYcat<-"<1 month"
unique(sp2$AGEYcat)
title<-paste0("Pediatric_XIE_",group[f],"_QID2W")
#title<-"Pediatric_XIE_Group1_Q4h2W"
dose<-c(0.003,0.005,0.007,0.009,0.01) #mg
fixed<-rep(0,length(dose))
dur<-seq(0,2*7)*24 #2 weeks
TAU<-6
qid<-sort(c(0+dur,6+dur,12+dur,18+dur))#QID
#qid<-sort(c(0+dur,4+dur,8+dur,12+dur,16+dur,20+dur))#Q4h
#qid<-sort(c(0+dur,3+dur,6+dur,9+dur,12+dur,15+dur,18+dur,21+dur))#Q3h
#time<-c(seq(0,24,0.1),seq(816,816+24,0.1)) #sampling times
flag<-NULL
flag[[1]]<-c(0,24,0.1)
flag[[2]]<-c(7*24,7*24+24,0.1)
flag[[3]]<-c(2*7*24,2*7*24+24,0.1)
flag[[4]]<-c(2*7*24+24,3*7*24,1)
time<-NULL
for(i in 1:length(flag)){
time1<-seq(flag[[i]][1],flag[[i]][2],flag[[i]][3])
time<-c(time,time1)
}
time<-sort(time)
head(sp2)
sp3<-NULL
for(i in 1:length(dose)){
sp4<-sp2
if(fixed[i]==1){
sp4$dose<-dose[i]*1000
sp4$dosegrp<-paste0(dose[i]*0.9," mg")
}else{sp4$dose<-dose[i]*1000*sp4$WT
sp4$dosegrp<-paste0(sigfig(dose[i]*0.9*1000,3)," \U03BCg/kg")}
sp3<-rbind(sp3,sp4)
}
orderx<-unique(sp3$dosegrp)
unique(sp3$AGEYcat)
head(sp3)
sp3$PNA[sp3$PNA==0]<-1/24/7
sp3$Ka = with(sp3,tvKa * exp(nKa))
sp3$V = with(sp3,tvV *(WT/70)^dVdWT* exp(nV))
sp3$Cl = with(sp3,tvCl*(WT/70)^dCldWT * exp(nCl)*(PNA^0.441/(4.06^0.441+PNA^0.441)))
sp3$V2 = with(sp3,tvV2 *(WT/70)^dVdWT* exp(nV2))
sp3$Cl2 = with(sp3,tvCl2 *(WT/70)^dCldWT * exp(nCl2))
sp3$Tlag = with(sp3,tvTlag * exp(nTlag))
sp3$bio =with(sp3,exp(tvF+nF)/(1+exp(tvF+nF)))
#make unique ID and carryover
sp3$ID<-seq(sp3$ID)
sp3$uid<-with(sp3,paste(ID,dosegrp,sep="-"))
length(unique(sp3$uid))
nrow(sp3)
uid<-nodup(sp3,c("uid","ID","AGEYcat","PNA","WT","dosegrp"),"var")
carryover<-c("uid","ID","AGEYcat","PNA","WT","PMA","dosegrp","Cl","Cl2","V","V2","Ka","bio")
intersect(carryover,names(sp3))
carryover<-nodup(sp3[,carryover],carryover,"all")
sp3<-as.data.table(sp3)
#SIM Start
test<-sp3[,as.data.frame(pkprofile(t.obs =time,
cl=Cl,
q=Cl2,
vc=V,
vp=V2,
ka=Ka,
dose=list(
amt=dose,t.dose=qid,
lag = Tlag,
f=bio))),
by=uid]
test$group<-NA
for(i in 1:length(flag)){
test$group[test$time>=flag[[i]][1]&test$time<=flag[[i]][2]]<-paste0("time",i)
}
write.csv(test,paste0("./output/",folder,"/","CONC_",title,".csv"))
#SIM STOP
##COMPUTE EXPOSURE
test1<-as.data.frame(test)
pro<-test1
#out<-addvar(pro[pro$time<=24,],c("uid"),"conc","max(x)","no","Cmax")
pro$uid1<-with(pro,paste(uid,group,sep="-"))
cminss<-addvar(pro,c("uid","group","uid1"),"conc","min(x)","no","Cminss")
cmaxss<-addvar(pro,c("uid","group","uid1"),"conc","max(x)","no","Cmaxss")
out<-left_join(cminss,cmaxss)
unique(uid$dosegrp)
#pro<-as.data.table(pro)
#auc1<-pro[time<=24,AUC(pro,time="time",id="uid",dv="conc")]
#names(auc1)<-c("uid","AUC24")
auc2<-AUC(pro,time="time",id="uid1",dv="conc")
out<-left_join(out,auc2)
##EFFECTIVE HALF-LIFE
ehl<-lhwide(out[,c("uid","group","AUC")],"AUC","group")
ehl$Rc <- with(ehl, (time3)/(time1))
ehl$EHL <- with(ehl, log(2) * TAU/(log(Rc/(Rc - 1))))
ehl<-ehl[,c("uid","Rc","EHL")]
###APPARENT HL
lda<-pro[pro$time>=355&pro$time<355+24,]
intm<-addvar(lda,"uid","time","min(x)","no","mintime")
lda$time<-lda$time-355
#ggplot(lda[lda$uid%in%unique(lda$uid)[1:4],],aes(x=time,y=conc,group=uid))+geom_line()
lda$dum<-2.7
lda$flag<-"dum"
library(linpk)
lda<-as.data.frame(lda)
hl<-nca.cal(data=lda,n_lambda = 3, id = "uid", time = "time",
dv = "conc")[,c("uid","HL")]
names(hl)<-c("uid","Lamda_HL")
####
out<-left_join(out,carryover)
out<-hl2cpt(out,cl="Cl", cl2="Cl2", v="V", v2="V2",c("HLa","HLb"))
head(out)
out<-left_join(out,ehl)
out<-left_join(out,hl)
out$Ratio<-with(out,Cminss/Cmaxss)
write.csv(out,paste0("./output/",folder,"/",title,"_expos.csv"))
}
nca.cal<-function (data = df, n_lambda = 3, id = "id", time = "TAD",
dv = "dv", partialAUC = c(0,20, 2, 14), partialConc = c(4, 5))
{
dat1<-data#$tad <- with(dat1,time - time1)
dat1$id<-dat1[,id]
dat1$time<-dat1[,time]
dat1$dv<-dat1[,dv]
dat1$uid<-dat1[,id]
dat1$tad<-dat1[,time]
dat1$tad[dat1$tad < 0] <- 0
dat2 <- dat1
dat2 <- dat2[order(dat2[,id], dat2$tad), ]
#idss <- nodup(dat, c("uid", "id", "dose", "OCC"), "var")
dat2$dvtm <- dat2[,dv] * dat2[,time]
datauc <- dat2
auclast <- AUC(datauc, time = time, id = id, dv = dv)
names(auclast) <- c(id, "AUClast")
aucmlast <- AUC(datauc, time = time, id = id, dv = "dvtm")
names(aucmlast) <- c(id, "AUMClast")
dat$tad1 <- dat$tad
aucpart <- NULL
if (!is.null(partialAUC)) {
nauc <- length(partialAUC)/2
for (z in seq(1, length(partialAUC), 2)) {
tm1 <- partialAUC[z]
tm2 <- partialAUC[z + 1]
auc <- AUC(dat[dat[, "tad1"] >= tm1 & dat[, "tad1"] <=
tm2, ], time = "tad1", id = id, dv = dv)
names(auc) <- c(id, paste0("AUC", tm1, "-", tm2))
if (z == 1) {
aucpart <- rbind(aucpart, auc)
}      else {
aucpart[, paste0("AUC", tm1, "-", tm2)] <- auc[,
2]
}
}
aucpart
}  else {
aucpart <- NULL
}
Cpart <- NULL
if (!is.null(partialConc)) {
nauc <- length(partialConc)
for (z in 1:length(partialConc)) {
tm1 <- partialConc[z]
partc <- dat[dat[, "tad1"] == tm1, c(id, dv)]
names(partc) <- c(id, paste0("C", tm1))
if (z == 1) {
Cpart <- rbind(Cpart, partc)
}      else {
Cpart<-left_join(Cpart, partc)
}
}
} else {
Cpart <- NULL
}
if (!is.null(n_lambda)) {
dat3<-dat2
dat3$time <- dat3$tad
dat3$tmp <- seq(nrow(dat3))
dat3 <- addvar(dat3, id, "tmp", "max(x)", "yes", "tmp2")
head(dat3)
dat3$tmp <- dat3$tmp2 - dat3$tmp
dat3 <- dat3[dat3$tmp < n_lambda, ]
test1 <- ddply(dat3[, c("uid", "time", "dv")], .(uid),
summarize, interc = lm(log(dv) ~ time)$coef[1], Lambda = lm(log(dv) ~
time)$coef[2] * -1, R2 = summary(lm(log(dv) ~
time))$r.squared, HL = (log(2)/lm(log(dv) ~ time)$coef[2]) *
-1, that = max(time))
test1$n_lambda <- n_lambda
test1$Clast_hat <- with(test1, exp(-Lambda * that + interc))
test1a <- ddply(dat3[, c("uid", "time", "dv","dvtm")], .(uid),
summarize, intercc = lm(log(dvtm) ~ time)$coef[1],
Lambdac = lm(log(dvtm) ~ time)$coef[2] * -1, R2c = summary(lm(log(dvtm) ~
time))$r.squared, HLc = (log(2)/lm(log(dvtm) ~
time)$coef[2]) * -1, thatc = max(time))
test1a$n_lambdac <- n_lambda
test1a$Clast_hatc <- with(test1a, exp(-Lambdac * thatc +
intercc))
}  else {
test1 <- NULL
}
if (TRUE %in% c(test1$HL < 0)) {
test1$Warning.HL.Negative = ifelse(test1$HL, "yes", "")
}
dat1$time1 <- dat1$time
max <- ddply(dat1[, c("uid", "dv", "time", "time1")], .(uid),
summarize, Cmax = max(dv), Tmax = time1[dv == max(dv)],
Cmin = min(dv[time >= time[dv == max(dv)]]), Tlast = max(dat$time1),
Clast = dv[time == max(time)])
maxa <- ddply(dat1, .(uid), summarize, Clastc = dvtm[time ==
max(time)])
head(dat1)
#test <- plyr::join(max, idss)
test <- plyr::join(max, maxa)
test <- plyr::join(test, auclast)
test <- plyr::join(test, aucmlast)
if (!is.null(n_lambda)) {
test <- join(test, test1)
test <- join(test, test1a)
test$AUCinf_obs <- abs(as.numeric(as.character(test$AUClast)) +
test$Clast/test$Lambda)
test$AUMCinf_obs <- abs(as.numeric(as.character(test$AUMClast)) +
test$Clastc/test$Lambdac)
test$AUCinf_pred <- abs(as.numeric(as.character(test$AUClast)) +
test$Clast_hat/test$Lambda)
test$AUMCinf_pred <- abs(as.numeric(as.character(test$AUMClast)) +
test$Clast_hatc/test$Lambdac)
test$MRTlast <- test$AUMClast/test$AUClast
test$MRTobs <- test$AUMCinf_obs/test$AUCinf_obs
test$MRTpred <- test$AUMCinf_pred/test$AUCinf_pred
}  else {
test$MRTlast <- test$AUMClast/test$AUClast
}
if (!is.null(Cpart)) {
test <- plyr::join(test, Cpart)
}
if (!is.null(aucpart)) {
test <- plyr::join(test, aucpart)
}
test$interc <- test$that <- NULL
test<-as.data.frame(test)
}
