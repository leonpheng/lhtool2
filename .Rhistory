#sp2$AGEYcat<-"<1 month"
unique(sp2$AGEYcat)
title<-paste0("Pediatric_XIE_",group[f],"_QID2W")
#title<-"Pediatric_XIE_Group1_Q4h2W"
nweek=3
dose<-c(0.001,0.003,0.005,0.007) #mg
fixed<-rep(0,length(dose))
dur<-seq(0,nweek*7)*24 #2 weeks
TAU<-24
qid<-sort(c(0+dur,6+dur,12+dur,18+dur))#QID
#qid<-sort(c(0+dur,4+dur,8+dur,12+dur,16+dur,20+dur))#Q4h
#qid<-sort(c(0+dur,3+dur,6+dur,9+dur,12+dur,15+dur,18+dur,21+dur))#Q3h
#time<-c(seq(0,24,0.1),seq(816,816+24,0.1)) #sampling times
##PK TIME
flag<-NULL
for(i in 1:(nweek+1)){
if(i==1){
flag[[i]]<-c(0,24,0.1)
}else{if(i>1&i<(nweek+1)){
flag[[i]]<-c((i-1)*7*24,(i-1)*7*24+24,0.1)}else{
flag[[i]]<-c((i-1)*7*24,(i-1)*7*24+24,0.1)
flag[[i+1]]<-c((i-1)*7*24+24,(i+1)*7*24,1)
}}}
lastdose=max(qid)
time<-NULL
for(i in 1:length(flag)){
time1<-seq(flag[[i]][1],flag[[i]][2],flag[[i]][3])
time<-c(time,time1)
}
time<-sort(time)
head(sp2)
sp3<-NULL
for(i in 1:length(dose)){
sp4<-sp2
if(fixed[i]==1){
sp4$dose<-dose[i]*1000
sp4$dosegrp<-paste0(dose[i]*0.9," mg")
}else{sp4$dose<-dose[i]*1000*sp4$WT
sp4$dosegrp<-paste0(sigfig(dose[i]*0.9*1000,3)," \U03BCg/kg")}
sp3<-rbind(sp3,sp4)
}
orderx<-unique(sp3$dosegrp)
unique(sp3$AGEYcat)
head(sp3)
sp3$PNA[sp3$PNA==0]<-1/24/7
sp3$Ka = with(sp3,tvKa * exp(nKa))
sp3$V = with(sp3,tvV *(WT/70)^dVdWT* exp(nV))
sp3$Cl = with(sp3,tvCl*(WT/70)^dCldWT * exp(nCl)*(PNA^0.441/(4.06^0.441+PNA^0.441)))
sp3$V2 = with(sp3,tvV2 *(WT/70)^dVdWT* exp(nV2))
sp3$Cl2 = with(sp3,tvCl2 *(WT/70)^dCldWT * exp(nCl2))
sp3$Tlag = with(sp3,tvTlag * exp(nTlag))
sp3$bio =with(sp3,exp(tvF+nF)/(1+exp(tvF+nF)))
#make unique ID and carryover
sp3$ID<-seq(sp3$ID)
sp3$uid<-with(sp3,paste(ID,dosegrp,sep="-"))
length(unique(sp3$uid))
nrow(sp3)
uid<-nodup(sp3,c("uid","ID","AGEYcat","PNA","WT","dosegrp"),"var")
carryover<-c("uid","ID","AGEYcat","PNA","WT","PMA","dosegrp","Cl","Cl2","V","V2","Ka","bio")
intersect(carryover,names(sp3))
carryover<-nodup(sp3[,carryover],carryover,"all")
sp3<-as.data.table(sp3)
#SIM Start
test<-sp3[,as.data.frame(pkprofile(t.obs =time,
cl=Cl,
q=Cl2,
vc=V,
vp=V2,
ka=Ka,
dose=list(
amt=dose,t.dose=qid,
lag = Tlag,
f=bio))),
by=uid]
test$group<-NA
for(i in 1:length(flag)){
test$group[test$time>=flag[[i]][1]&test$time<=flag[[i]][2]]<-paste0("time",i)
}
write.csv(test,paste0("./output/",folder,"/",s,"_CONC_",title,".csv"))
#SIM STOP
##COMPUTE EXPOSURE
test1<-as.data.frame(test)
pro<-test1
#out<-addvar(pro[pro$time<=24,],c("uid"),"conc","max(x)","no","Cmax")
pro$uid1<-with(pro,paste(uid,group,sep="-"))
cminss<-addvar(pro,c("uid","group","uid1"),"conc","min(x)","no","Cminss")
cmaxss<-addvar(pro,c("uid","group","uid1"),"conc","max(x)","no","Cmaxss")
out<-left_join(cminss,cmaxss)
unique(uid$dosegrp)
#pro<-as.data.table(pro)
#auc1<-pro[time<=24,AUC(pro,time="time",id="uid",dv="conc")]
#names(auc1)<-c("uid","AUC24")
auc2<-AUC(pro,time="time",id="uid1",dv="conc")
out<-left_join(out,auc2)
##EFFECTIVE HALF-LIFE
ehl<-lhwide(out[,c("uid","group","AUC")],"AUC","group")
ehl$Rc <- with(ehl, (time3)/(time1))
ehl$EHL <- with(ehl, log(2) * TAU/(log(Rc/(Rc - 1))))
ehl<-ehl[,c("uid","Rc","EHL")]
###APPARENT HL
lda<-pro[pro$time>=lastdose&pro$time<lastdose+24,]
intm<-addvar(lda,"uid","time","min(x)","no","mintime")
lda$time<-lda$time-lastdose
#ggplot(lda[lda$uid%in%unique(lda$uid)[1:4],],aes(x=time,y=conc,group=uid))+geom_line()
#lda$dum<-2.7
#lda$flag<-"dum"
lda<-as.data.frame(lda)
hl<-nca.cal(data=lda,n_lambda =4, id = "uid", time = "time",
dv = "conc")[,c("uid","HL")]
names(hl)<-c("uid","Lamda_HL")
####
out<-left_join(out,carryover)
out<-hl2cpt(out,cl="Cl", cl2="Cl2", v="V", v2="V2",c("HLa","HLb"))
head(out)
out<-left_join(out,ehl)
out<-left_join(out,hl)
out$Ratio<-with(out,Cminss/Cmaxss)
write.csv(out,paste0("./output/",folder,"/",s,"_",title,"_expos.csv"))
}}
