gr2<-paste0("Grade >=2\n [N=",length(unique(saf$USUBJID[saf$TOXGRADE>=2]))," (",sigfig(length(unique(saf$USUBJID[saf$TOXGRADE>=2]))/totid*100,3),"%)]")#57 57/57
gr3<-paste0("Grade >=3\n [N=",length(unique(saf$USUBJID[saf$TOXGRADE>=3]))," (",sigfig(length(unique(saf$USUBJID[saf$TOXGRADE>=3]))/totid*100,3),"%)")
gr4<-paste0("Grade >=4\n [N=",length(unique(saf$USUBJID[saf$TOXGRADE>=4]))," (",sigfig(length(unique(saf$USUBJID[saf$TOXGRADE>=4]))/totid*100,3),"%)]")
