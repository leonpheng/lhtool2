te1$AEDECOD[te1$MEDDRA=="Alopecia"]<-"Alopecia"
te1$AEDECOD[te1$MEDDRA%in%c("Aspartate aminotransferase increased")]<-"Increased AST"
te1$AEDECOD[te1$MEDDRA=="Alanine aminotransferase increased"]<-"Increased ALT"
