ggplot(pld,aes(x=y,y=value,col=variable))+
geom_line()
pna<-data.frame(d=seq(1,365*18),w=seq(1,365*18)/7,y=seq(1,365*18)/365)
pna$Xie<-(pna$d^0.441/(4.06^0.441+pna$d^0.441))
pna$Pott<-(1-(1-0.262)*exp(-(pna$d/7)*log(2)/25.7))
pna$CYPEGFR<-((0.2*((pna$w+42)^3.4)/(47.7^3.4+(pna$w+42)^3.4))+(0.8*(((1.01)*pna$y/(0.101+pna$y))+0.036)))
head(pld)
pld<-lhlong(pna,c("Xie","Pott","CYPEGFR"))
ggplot(pld,aes(x=y,y=value,col=variable))+
geom_line()
pna<-data.frame(d=seq(1,365*2),w=seq(1,365*2)/7,y=seq(1,365*2)/365)
pna$Xie<-(pna$d^0.441/(4.06^0.441+pna$d^0.441))
pna$Pott<-(1-(1-0.262)*exp(-(pna$d/7)*log(2)/25.7))
pna$CYPEGFR<-((0.2*((pna$w+42)^3.4)/(47.7^3.4+(pna$w+42)^3.4))+(0.8*(((1.01)*pna$y/(0.101+pna$y))+0.036)))
