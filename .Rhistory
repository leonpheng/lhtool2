t5$AEBODSYS<-NULL
head(lhflex)
t6<-lhflex(table1=t5,select=names(t5),add.h =data.frame(x=c("Dictionary-Derived Term of AEs of interest",rep(all1,each=2)),y=c("Dictionary-Derived Term of AEs of interest",rep(c("Event Frequency","Subject Frequency"),5))))
